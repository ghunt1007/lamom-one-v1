# LAMOM ONE — Environment Variables
# Copy this file to .env.local and fill in your actual values
# .env.local is gitignored and will never be committed

# Firebase (ดึงจาก Firebase Console > Project Settings > Your Apps)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=lamom-one-v1.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=lamom-one-v1
VITE_FIREBASE_STORAGE_BUCKET=lamom-one-v1.appspot.com
VITE_FIREBASE_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000000000000000

# Firebase App Check (P27) — ป้องกัน unauthorized Firebase API calls
# ดึง reCAPTCHA v3 Site Key จาก: Google reCAPTCHA Console → ลงทะเบียนแอป → Site Key
# จากนั้นเปิด Firebase Console → App Check → ลงทะเบียน reCAPTCHA provider
# ถ้าไม่ตั้งค่า App Check จะถูกข้ามไป (dev/demo ยังใช้ได้ปกติ)
# VITE_FIREBASE_APP_CHECK_KEY=your_recaptcha_v3_site_key_here

# Gemini AI — LAMI AI จริง (ฟรี 100% — ขอ key ที่ https://aistudio.google.com/app/apikey)
# ถ้าไม่ตั้งค่า LAMI จะทำงานใน Demo Mode อัตโนมัติ
# VITE_GEMINI_API_KEY=AIza...

# Cloudflare R2 — File Storage (ฟรี 10 GB)
# URL ของ Cloudflare Worker ที่ handle R2 upload (ตั้งค่าหลัง deploy worker)
# VITE_R2_WORKER_URL=https://r2-upload.your-name.workers.dev
