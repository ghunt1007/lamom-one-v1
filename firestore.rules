rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // สิทธิ์แบบจำกัดเวลา (accessExpiresAt) — ถ้า field นี้มีค่าและผ่านมาแล้ว ถือว่าหมดสิทธิ์ทันที
    // ไม่ว่า field "role" จะยังเป็นอะไรอยู่ก็ตาม (บังคับที่ระดับ rules จริง ไม่ใช่แค่ซ่อนปุ่มที่ UI
    // ซึ่งหลบเลี่ยงได้ด้วยการยิง request ตรง) ไม่มี field นี้ (null) = สิทธิ์ไม่มีวันหมดอายุตามปกติ
    function userRole() {
      return isSignedIn()
        ? roleFromProfile(get(/databases/$(database)/documents/users/$(uid())).data)
        : 'anonymous';
    }

    function roleFromProfile(profile) {
      return (profile.get('accessExpiresAt', null) != null && profile.get('accessExpiresAt', null) < request.time)
        ? 'expired'
        : profile.get('role', 'viewer');
    }

    function isOwner() {
      return isSignedIn() && userRole() == 'owner';
    }

    function isAdmin() {
      return isSignedIn() && userRole() in ['owner', 'admin'];
    }

    function isManager() {
      return isSignedIn() && userRole() in ['owner', 'admin', 'manager'];
    }

    function isStaff() {
      return isSignedIn() && userRole() in ['owner', 'admin', 'manager', 'sales', 'service', 'finance', 'hr', 'staff'];
    }

    function isFinance() {
      return isSignedIn() && userRole() in ['owner', 'admin', 'manager', 'finance'];
    }

    function isHR() {
      return isSignedIn() && userRole() in ['owner', 'admin', 'manager', 'hr'];
    }

    function isService() {
      return isSignedIn() && userRole() in ['owner', 'admin', 'manager', 'service'];
    }

    function isSales() {
      return isSignedIn() && userRole() in ['owner', 'admin', 'manager', 'sales'];
    }

    // ระบบยังไม่มีผู้ใช้คนแรก (ยังไม่มี meta/init) — ใช้ตอน bootstrap owner คนแรกเท่านั้น
    function isBootstrapping() {
      return !exists(/databases/$(database)/documents/meta/init);
    }

    // ── Meta / System Init ────────────────────────────────────────────────────
    // Any signed-in user can read (to detect first-user scenario)
    // Any signed-in user can create init doc (first-time bootstrap)
    // Only admin can update/delete
    match /meta/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // AI personal data — subcollections (private per user)
    match /users/{userId}/ai_memories/{docId} {
      allow read, write: if isSignedIn() && uid() == userId;
    }
    match /users/{userId}/ai_conversations/{docId} {
      allow read, write: if isSignedIn() && uid() == userId;
    }

    match /users/{userId} {
      // แก้ไข (2026-07-23): เดิมใช้ isAdmin() (owner/admin เท่านั้น) แต่หน้า User Management ของแอป
      // เขียนไว้ชัดเจนว่า "ผู้จัดการขึ้นไป" (manager level 70 ≥ MIN_CREATE_LEVEL 60) จัดการผู้ใช้ได้ —
      // แปลว่า manager กด UserManagement มาก่อนหน้านี้จะเจอ permission-denied ตอนอ่านรายชื่อผู้ใช้เลย
      // (bug ที่ค้างมาก่อน ไม่เกี่ยวกับงานตอนนี้ แต่ไปกระทบฟีเจอร์ต่ออายุสิทธิ์ที่เพิ่มใหม่โดยตรง) แก้ให้ตรง
      // กับที่ UI ตั้งใจไว้จริง — ยังไม่ได้เพิ่มการตรวจ "ต้องสร้าง/แก้ role ต่ำกว่าตัวเองเท่านั้น" ที่ระดับ
      // rules (ตอนนี้ตรวจแค่ที่ UI ฝั่ง client เท่านั้น เหมือนที่ isAdmin() เดิมก็ไม่ตรวจระดับกันอยู่แล้ว)
      allow read: if isSignedIn() && (uid() == userId || isManager());
      // Self-create only allowed as the very first owner (bootstrap, no meta/init yet)
      // or as a 'pending' account awaiting admin approval — never with a privileged role.
      // ป้องกัน privilege escalation: ผู้ใช้ทั่วไปสร้าง/แก้ profile ตัวเองให้เป็น owner/admin เองไม่ได้
      allow create: if isManager()
        || (isSignedIn() && uid() == userId && isBootstrapping() && request.resource.data.role == 'owner')
        || (isSignedIn() && uid() == userId && !isBootstrapping() && request.resource.data.role == 'pending');
      // ผู้ใช้แก้ไข field ตัวเองได้ (เช่น displayName) แต่ห้ามแก้ role/permissions/active/accessExpiresAt เอง
      // เด็ดขาด ต้องให้ manager ขึ้นไปเป็นคนเปลี่ยนสิทธิ์เท่านั้น
      allow update: if isManager()
        || (isSignedIn() && uid() == userId
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'permissions', 'active', 'accessExpiresAt']));
      allow delete: if isOwner();
    }

    // ── Roles & Permissions — owner only ─────────────────────────────────────
    match /roles/{docId} {
      allow read: if isStaff();
      allow write: if isOwner();
    }

    // ── Audit Logs — immutable once written ──────────────────────────────────
    // ชื่อ collection จริงคือ audit_log (ไม่ใช่ auditLogs) — เดิม rule นี้ไม่มีผลจริงเลย
    // เพราะชื่อไม่ตรงกับที่ src/core/db.js เขียนจริง เลยตกไปใช้ default rule ท้ายไฟล์
    // ซึ่งอนุญาตให้ staff แก้ไข/ลบได้ — ทำลายหลักฐาน audit ได้ ตอนนี้แก้ให้ตรงชื่อจริงแล้ว
    match /audit_log/{docId} {
      allow read: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    // ── Branches & Settings — admin manages ──────────────────────────────────
    match /settings/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /branches/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── CRM & Sales ──────────────────────────────────────────────────────────
    match /customers/{docId} {
      allow read, write: if isStaff();
    }

    match /leads/{docId} {
      allow read, write: if isStaff();
    }

    match /bookings/{docId} {
      allow read, write: if isStaff();
    }

    match /sales/{docId} {
      allow read, write: if isStaff();
    }

    match /comm_logs/{docId} {
      allow read, write: if isStaff();
    }

    match /tasks/{docId} {
      allow read, write: if isStaff();
    }

    match /quotations/{docId} {
      allow read, write: if isStaff();
    }

    match /follow_ups/{docId} {
      allow read, write: if isStaff();
    }

    match /test_drives/{docId} {
      allow read, write: if isStaff();
    }

    match /appointments/{docId} {
      allow read, write: if isStaff();
    }

    // ── Stock & Vehicles ─────────────────────────────────────────────────────
    match /vehicles/{docId} {
      allow read, write: if isStaff();
    }

    match /vehicle_orders/{docId} {
      allow read, write: if isStaff();
    }

    match /parts/{docId} {
      allow read, write: if isStaff();
    }

    match /pdi/{docId} {
      allow read, write: if isStaff();
    }

    match /job_cards/{docId} {
      allow read, write: if isStaff();
    }

    match /service_appointments/{docId} {
      allow read, write: if isStaff();
    }

    // ── Finance — finance role & above ────────────────────────────────────────
    match /commissions/{docId} {
      allow read: if isFinance() || isManager();
      allow write: if isFinance();
    }

    match /payroll/{docId} {
      allow read: if isFinance() || isManager();
      allow write: if isFinance();
    }

    match /petty_cash/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isFinance() || isManager();
    }

    match /withholding_tax_certs/{docId} {
      allow read, write: if isFinance();
    }

    match /billing_runs/{docId} {
      allow read, write: if isFinance();
    }

    match /custom_order_docs/{docId} {
      allow read, write: if isFinance();
    }

    match /expenses/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isFinance() || isManager();
    }

    match /expense_approvals/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isManager();
    }

    match /cash_flow/{docId} {
      allow read: if isFinance() || isManager();
      allow write: if isFinance();
    }

    match /bank_reconciliation/{docId} {
      allow read, write: if isFinance();
    }

    match /bank_transactions/{docId} {
      allow read, write: if isFinance();
    }

    match /payroll_records/{docId} {
      allow read: if isFinance() || isManager();
      allow write: if isFinance();
    }

    match /salary_scale_staff/{docId} {
      allow read: if isFinance() || isManager();
      allow write: if isFinance();
    }

    match /bonus_pool_staff/{docId} {
      allow read: if isFinance() || isManager();
      allow write: if isFinance();
    }

    // ช่างอ่านได้ (เช็คสถานะโบนัสตัวเอง) แต่การ "อนุมัติ" (create) ต้องผู้จัดการ/การเงินเท่านั้น เพราะสั่งจ่ายเงินจริง
    match /tech_kpi_bonus_approvals/{docId} {
      allow read: if isStaff();
      allow write: if isFinance() || isManager();
    }

    match /financial_closings/{docId} {
      allow read, write: if isFinance();
    }

    match /debt_settlements/{docId} {
      allow read, write: if isFinance();
    }

    match /expense_claims/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isHR() || isManager();
    }

    // ── HR — HR role & above ──────────────────────────────────────────────────
    match /staff/{docId} {
      allow read: if isStaff();
      allow write: if isHR();
    }

    match /staff_loans/{docId} {
      allow read: if isHR() || isManager();
      allow create: if isStaff();
      allow update, delete: if isHR();
    }

    match /leave_requests/{docId} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isHR() || isManager();
    }

    match /attendance/{docId} {
      allow read: if isStaff();
      allow write: if isHR() || isManager();
    }

    match /performance_reviews/{docId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    match /team_targets/{docId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    match /employee_evaluations/{docId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    match /disciplinary_records/{docId} {
      allow read: if isHR() || isManager();
      allow write: if isHR() || isManager();
    }

    match /recruitment/{docId} {
      allow read, write: if isHR() || isManager();
    }

    match /onboarding_staff/{docId} {
      allow read, write: if isHR() || isManager();
    }

    match /offboarding_staff/{docId} {
      allow read, write: if isHR() || isManager();
    }

    // ── Insurance ─────────────────────────────────────────────────────────────
    match /insurance_policies/{docId} {
      allow read, write: if isStaff();
    }

    match /insurance_claims/{docId} {
      allow read, write: if isStaff();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read: if isSignedIn() &&
        (resource.data.get('userId', '') == uid() || isAdmin());
      allow create: if isStaff();
      allow update: if isSignedIn() &&
        (resource.data.get('userId', '') == uid() || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Marketing & Events ────────────────────────────────────────────────────
    match /campaigns/{docId} {
      allow read, write: if isStaff();
    }

    match /events/{docId} {
      allow read, write: if isStaff();
    }

    match /promotions/{docId} {
      allow read, write: if isStaff();
    }

    // ── Quality & Compliance ─────────────────────────────────────────────────
    match /complaints/{docId} {
      allow read, write: if isStaff();
    }

    match /inspections/{docId} {
      allow read, write: if isService() || isManager();
    }

    match /sop_documents/{docId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    match /legal_references/{docId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    // ── RAG (Phase 3) — embedding ของความรู้ภายใน (SOP/คู่มือ/Product Knowledge/กฎหมาย)
    // เขียนอัตโนมัติจาก core/db.js ทุกครั้งที่แหล่งข้อมูลต้นทางถูกสร้าง/แก้ไข — สิทธิ์เท่ากับ
    // การอ่าน/เขียนข้อมูลต้นทางเหล่านั้นเอง (ไม่มีข้อมูลลูกค้า/ธุรกิจส่วนตัวอยู่ใน Phase นี้)
    match /rag_chunks/{docId} {
      allow read, write: if isStaff();
    }

    // ── Shared reference data & org-wide settings — admin manages ────────────
    match /master_data/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /company_profile/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /whitelabel_settings/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /sms_otp_settings/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Finance-adjacent config — finance role manages ────────────────────────
    match /bank_partner_info/{docId} {
      allow read, write: if isFinance();
    }

    match /insurance_rate_cards/{docId} {
      allow read, write: if isFinance() || isManager();
    }

    match /insurance_proposals/{docId} {
      allow read, write: if isStaff();
    }

    match /payment_transactions/{docId} {
      allow read, write: if isStaff();
    }

    match /installment_plans/{docId} {
      allow read, write: if isStaff();
    }

    match /charging_sessions/{docId} {
      allow read, write: if isStaff();
    }

    // ── Gamification (game-integrity only, not real money — staff-writable) ──
    match /gamification_events/{docId} {
      allow read, write: if isStaff();
    }

    match /staff_points/{docId} {
      allow read, write: if isStaff();
    }

    // ── AI Officer chat history — private per user ────────────────────────────
    match /ai_officer_chats/{docId} {
      allow read, update, delete: if isSignedIn() && resource.data.get('userId', '') == uid();
      allow create: if isStaff() && request.resource.data.get('userId', '') == uid();
    }

    // ── Client-side error monitoring — anyone signed in can report, only staff manage ──
    match /error_log/{docId} {
      allow read, update, delete: if isStaff();
      allow create: if isSignedIn();
    }

    // ── System security — admin only (ค่า secret จริง/ปิด-เปิดนโยบายทั้งองค์กร/ยกเลิก session คนอื่น) ──
    match /api_keys/{docId} {
      allow read, write: if isAdmin();
    }

    match /security_policies/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /security_sessions/{docId} {
      allow read, write: if isAdmin();
    }

    // ── PDPA — พนักงานบันทึกความยินยอมได้ตามงานปกติ แต่คำขอสิทธิ์ตามกฎหมาย (DSR) ต้องผู้จัดการปิดงาน ──
    match /pdpa_consents/{docId} {
      allow read, write: if isStaff();
    }

    match /pdpa_dsr_requests/{docId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    // ── Default: any other collection requires staff auth ────────────────────
    // สำคัญมาก (พบ 2026-07-23 ระหว่างเขียนเทส rules ครั้งแรกของโปรเจกต์): Firestore ประเมิน
    // "ทุก" match block ที่ path ตรงกัน แล้วรวมผลแบบ OR — ไม่ใช่ "block เจาะจงกว่าชนะ" อย่างที่คนมัก
    // เข้าใจผิด แปลว่า catch-all นี้ (isStaff() แบบกว้างๆ) จะ "แข่ง" กับทุก match block ด้านบนที่จำกัด
    // สิทธิ์แคบกว่า isStaff() เสมอ (เช่น payroll ที่ควรเป็น isFinance() เท่านั้น, audit_log ที่ห้ามแก้ไข/
    // ลบเด็ดขาด, users ที่ควรจำกัดที่ isManager()) — ถ้าไม่กันไว้ตรงนี้ staff ธรรมดาทุกคนจะยังอ่าน/เขียน
    // collection เหล่านั้นได้อยู่ดีผ่าน catch-all นี้ โดยไม่ต้องผ่านเงื่อนไขที่เข้มกว่าเลย (ยืนยันด้วยเทสจริง
    // ผ่าน emulator แล้ว — sales role อ่าน/เขียน users collection ได้ทั้งที่ควรจะถูกบล็อก จนกว่าจะกันตรงนี้)
    // ต้องเพิ่มชื่อ collection ใหม่ในลิสต์นี้ทุกครั้งที่เขียน match block ที่จำกัดสิทธิ์แคบกว่า isStaff()
    function hasNarrowerRuleThanStaff(collection) {
      return collection in [
        'meta', 'users', 'roles', 'audit_log', 'settings', 'branches',
        'commissions', 'payroll', 'petty_cash', 'withholding_tax_certs', 'billing_runs', 'custom_order_docs',
        'expenses', 'expense_approvals', 'cash_flow', 'bank_reconciliation', 'bank_transactions',
        'payroll_records', 'salary_scale_staff', 'bonus_pool_staff', 'tech_kpi_bonus_approvals',
        'financial_closings', 'debt_settlements', 'expense_claims',
        'staff', 'staff_loans', 'leave_requests', 'attendance', 'performance_reviews', 'team_targets',
        'employee_evaluations', 'disciplinary_records', 'recruitment', 'onboarding_staff', 'offboarding_staff',
        'notifications', 'inspections', 'sop_documents', 'legal_references',
        'master_data', 'company_profile', 'whitelabel_settings', 'sms_otp_settings',
        'bank_partner_info', 'insurance_rate_cards', 'ai_officer_chats',
        'api_keys', 'security_policies', 'security_sessions',
        'pdpa_consents', 'pdpa_dsr_requests'
      ];
    }

    match /{collection}/{docId} {
      allow read, write: if isStaff() && !hasNarrowerRuleThanStaff(collection);
    }
  }
}
